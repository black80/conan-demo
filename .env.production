# Baked into the default `npm run build` (production mode): the static demo deploy
# serves mocked data recorded from the real backend — no server, no API key, no cost.
# `npm run dev` never loads this file and keeps talking to the live backend.
# This file is committed on purpose (no secrets); see .gitignore's !.env.production.
VITE_USE_MOCKS=true
# Display-only in mock mode (Settings page); no request ever leaves the browser.
VITE_API_URL=mock://demo
